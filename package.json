{
  "name": "exxat-ui-project",
  "version": "0.0.1",
  "description": "Builder-facing starter app built on @exxatdesignux/ui. Vite + React + react-router-dom with the Exxat shell, tokens, product routing, and DS guardrails wired in.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "exxat-ui sync-extras --quiet --no-upgrade-notice || true && exxat-ui upgrade --quiet || true",
    "predev": "exxat-ui dev-guard",
    "dev": "vite",
    "dev:5001": "vite --port 5001",
    "dev:5005": "vite --port 5005",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "fa:subset-audit": "node scripts/fontawesome-subset-audit.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@exxatdesignux/product-framework": "^0.1.7",
    "@exxatdesignux/ui": "^0.6.47",
    "@fontsource-variable/inter": "^5.2.5",
    "@hookform/resolvers": "^5.2.2",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-is": "^19.2.6",
    "react-resizable-panels": "^4.10.0",
    "react-router-dom": "^7.1.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "ws": "^8.20.1",
    "@exxatdesignux/product-framework": "^0.1.7"
  },
  "pnpm": {
    "overrides": {
      "@exxatdesignux/product-framework": "^0.1.7"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver"
    ],
    "allowedDeprecatedVersions": {
      "node-domexception": "1.0.0",
      "whatwg-encoding": "3.1.1"
    }
  }
}
